{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for Quran Similarity Learning Web App",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup": "node scripts/maintenance/setup.js",
    "init-db": "npm run setup",
    "db:setup": "node scripts/setup/setupDatabase.js",
